# --- LLM (required) ---
# Get a free key at https://console.groq.com
GROQ_API_KEY=

# --- Optional: evaluation / LLMOps ---
OPENAI_API_KEY=
COMET_API_KEY=

# --- Database ---
MONGO_URI=mongodb://philoagents:philoagents@localhost:27017/?directConnection=true

# --- Auth (required for login) ---
# Any long random string. Used to sign login tokens. CHANGE THIS in production.
JWT_SECRET=change-me-to-a-long-random-string

# --- OAuth: Sign in with Google (optional) ---
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must be: http://localhost:8000/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- OAuth: Sign in with Slack (optional) ---
# Create an app at https://api.slack.com/apps  (enable "Sign in with Slack" / OpenID Connect)
# Redirect URL must be: http://localhost:8000/auth/slack/callback
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Where the browser is sent back to after OAuth, and this API's public base URL.
# Defaults are fine for local dev.
FRONTEND_URL=http://localhost:8080
OAUTH_REDIRECT_BASE=http://localhost:8000

# --- Jira (optional) ---
# Set all three to let personas (PM, SWE, Designer, CTO) fetch your REAL assigned
# issues instead of making them up. Leave blank to disable the Jira tool.
# Create an API token at https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
